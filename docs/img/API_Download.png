<script>
$(document).ready(function() {                                   
    searchbox_input_changed=false;
    $('#search-expand').on('shown.bs.dropdown', function(e) {
        $('#searchField').focus();
    });
    function onSubmitSearch(event){
      event.preventDefault();
    }
  // Desktop only (your megamenu CSS is >= 992px)
  if (!window.matchMedia || !window.matchMedia('(min-width: 992px)').matches) return;
  var header = document.getElementById('ibkr-header');
  if (!header) return;
  var bottom = header.querySelector('#ibkr-nav-bottom');
  if (!bottom) return;
  // Only bottom megamenus (the ones with .bottom-group)
  var bottomLis = Array.prototype.slice.call(
    bottom.querySelectorAll('.nav-item.dropdown')
  ).filter(function (li) {
    return !!li.querySelector('.dropdown-menu.bottom-group');
  });
  function blurIfFocusInside(container) {
    var ae = document.activeElement;
    if (container && ae && container.contains(ae) && typeof ae.blur === 'function') {
      ae.blur(); // breaks :focus-within
    }
  }
  function hardClose(li) {
    if (!li) return;
    // IMPORTANT: break :focus-within before stripping classes
    blurIfFocusInside(li);
    // If Bootstrap owns a dropdown instance for this toggle (i.e., it was click-opened),
    // ask it to hide cleanly.
    var toggle = li.querySelector('[data-bs-toggle="dropdown"]');
    if (toggle && window.bootstrap && bootstrap.Dropdown) {
      var inst = bootstrap.Dropdown.getInstance(toggle);
      if (inst) inst.hide();
    }
    // Safety: strip any remaining .show (Bootstrap sometimes leaves one behind)
    li.classList.remove('show');
    if (toggle) {
      toggle.classList.remove('show');
      toggle.setAttribute('aria-expanded', 'false');
    }
    var menu = li.querySelector('.dropdown-menu');
    if (menu) menu.classList.remove('show');
  }
  function closeAllBottomExcept(activeLi) {
    bottomLis.forEach(function (li) {
      if (li === activeLi) return;
      hardClose(li);
    });
    // Also close Search + Language so only one dropdown area is ever visible
    hardClose(header.querySelector('#search-expand'));
    hardClose(header.querySelector('#language-expand'));
  }
  // When hovering/focusing a bottom item, close any other pinned-open dropdowns
  bottomLis.forEach(function (li) {
    li.addEventListener('mouseenter', function () {
      closeAllBottomExcept(li);
    }, { passive: true });
    li.addEventListener('focusin', function () {
      closeAllBottomExcept(li);
    });
  });
});
function onClickFP(event){
    const hrefValue = event.currentTarget.getAttribute('href');
    event.preventDefault();
    setTimeout(() => {
        window.location.href = hrefValue;
    }, 500);
}
</script><script>$(function() { setCookie("IB_EMPRO", '1', 365, '.interactivebrokers.com'); });</script>
