<div id="app"></div>
<script type="module">
// Obtain disclosure details
const disclosure = document.querySelector('footer div.container div.row div.col').innerHTML;
// Links for buttons in search header (need to check if megamenu or old)
let login = 'ndcdyn.interactivebrokers.com/sso/Login?RL=1&locale=en_US';  // fallback
let open_account = 'ndcdyn.interactivebrokers.com/Universal/Application'; // fallback;
// Megamenu Links
if (document.querySelector('#nav-log-in')) {
  login = document.querySelector('#nav-log-in').href;
}
if (document.querySelector('#nav-open-account')) {
  open_account = document.querySelector('#nav-open-account').href;
}
// Old Links
if (document.querySelector('.dropdown-portal')) {
  login = document.querySelector('.dropdown-login .dropdown-portal').href;
}
if (document.querySelector('.dropdown-open-account .dropdown-portal')) {
  open_account = document.querySelector('.dropdown-open-account .dropdown-portal').href;
}
const currentDate = new Date();
const roundedMinutes = Math.floor(currentDate.getUTCMinutes() / 2) * 2;
const roundedDate = new Date(
  Date.UTC(currentDate.getUTCFullYear(), currentDate.getUTCMonth(), currentDate.getUTCDate(), currentDate.getUTCHours(), roundedMinutes, 0, 0)
);
const moduleImportUrl = '/webui/website.search/version/3.2.0/module/module.es.js';
try {
  //const moduleExport = await import(`${moduleImportUrl}?t=${roundedDate.getTime()}`);
  const moduleExport = await import(`${moduleImportUrl}`);
  const moduleConfig = moduleExport.default;
  const moduleAPI = await moduleConfig.mountModule('#app', {
    component: moduleConfig.componentStore.WebsiteSearch,
    props: {
      viewConfig: { footerHtml: disclosure }
    }
  });
  moduleAPI.onEmit('login', function() {
    window.location.href = '/sso/Login';
  });
  moduleAPI.onEmit('open_account', function() {
    window.location.href = '/Universal/Application';
  });
  moduleAPI.onEmit('new_search', function(query) {
    console.log('New search:', query);
  });
  moduleAPI.onEmit('error', function(err) {
    console.error('Search error:', err);
  });
} catch (error) {
  console.error(`Error loading search. Error: ${error}`);
}
</script></div>
