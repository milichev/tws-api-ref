		float: var(--dir-end);
		margin: 0px 4px;
		padding: 6px 10px;
		width: auto !important;
		height: auto;
		font-weight: var(--fw-400);
		font-size: .875rem;
		line-height: 1.25rem;
		text-align: center;
		color: var(--nav-bottom-bg-color);
		background-color: var(--primary);
		border-color: var(--primary);
		border-radius: var(--border-radius)
	}
	/* CTA area styling ------------------------------- */
	.mega-cta {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 30px;
		background: var(--black-80);
		background: radial-gradient(circle at top right, rgb(133, 143, 159) 1%, rgb(20, 20, 20) 100%);
	}
	[dir="rtl"] .mega-cta {
		background: radial-gradient(circle at top left, rgb(133, 143, 159) 1%, rgb(20, 20, 20) 100%);
	}
	.mega-cta img.cta-qr {
		max-width: 140px;
	}
	.mega-cta hr {
		border-color: var(--light-10);
	}
	.mega-cta .headline {
		padding: 0 0 1rem 0;
		font-size: var(--fs-3);
		line-height: var(--lh-4);
		color: var(--white);
		font-weight: var(--fw-600);
	}
	.mega-cta .headline-sub {
		/*padding: 0 0 1rem 0;*/
		font-size: var(--fs-5);
		line-height: var(--lh-5);
		color: var(--white);
		font-weight: var(--fw-600);
	}
	.mega-cta p {
		padding: 0;
		font-size: var(--fs-7);
		line-height: 1.5rem;
		color: var(--white-70);
	}
	.mega-cta p a {
		text-decoration: dotted;
		font-size: var(--fs-7);
		line-height: var(--lh-7);
	}
	.mega-cta .mega-cta-sublink {
		color: var(--white-70);
		padding-bottom: 0.5rem;
	}
	.mega-cta .mega-cta-sublink svg {
		fill: var(--white-70);
	}
	.mega-cta .mega-cta-sublink:hover, .mega-cta .mega-cta-sublink:focus-within {
		color: var(--white-90);
		transform: translateX(4px);
		transition: transform 0.18s ease, color 0.18s ease;
	}
	[dir="rtl"] .mega-cta .mega-cta-sublink:hover, [dir="rtl"] .mega-cta .mega-cta-sublink:focus-within {
		transform: translateX(-4px);
	}
	.mega-cta .mega-cta-sublink:hover svg, .mega-cta .mega-cta-sublink:focus-within svg {
		fill: var(--white-90);
		transition: transform 0.18s ease, fill 0.18s ease;
	}
	.mega-cta .mega-cta-btn {
		position: relative;
		bottom: 0;
		width: 100%;
	}
	.mega-cta .mega-cta-btn-wrap {
		position: relative;
		height: 100%;
	}
	.ibkr-header .navbar-bottom {
		position: relative;
		z-index: 10;
	}
	.ibkr-header .navbar-bottom .nav-item.dropdown {
		position: static;
	}
	.ibkr-header .navbar-bottom .dropdown-menu {
		position: absolute;
		left: 0;
		right: 0;
		top: 45px;
		margin: 0 auto;
		min-width: 0;
		min-height: 0;
		border-top: none;
		display: flex;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		z-index: 1040;
		/* below icon z-index 1050, above page content */
		max-height: 0;
		overflow: hidden;
		text-align: left;
	}
	[dir="rtl"] .ibkr-header .navbar-bottom .dropdown-menu {
		text-align: right;
	}
	/* Language icon */
	.ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item.li-language, .ibkr-header .navbar.navbar-bottom .container-fluid .navbar-nav .nav-item.li-language {
		margin: 0;
	}
	.ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item a.nav-link.nav-language, .ibkr-header .navbar.navbar-bottom .container-fluid .navbar-nav .nav-item a.nav-link.nav-language {
		padding: 0px 0px 14px;
		margin: -5px 0 0;
	}
	.ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item a.nav-link.nav-language svg, .ibkr-header .navbar.navbar-bottom .container-fluid .navbar-nav .nav-item a.nav-link.nav-language svg {
		padding: 2px 2px 2px 4px;
		border: 1px solid var(--dark-80);
		margin: auto 8px;
		border-radius: 8px;
		border-bottom-right-radius: 0;
		height: 20px;
		width: 30px;
	}
	.ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item a.nav-link.nav-language::after, .ibkr-header .navbar.navbar-bottom .container-fluid .navbar-nav .nav-item a.nav-link.nav-language::after {
		display: none;
	}
	/* .dropdown-menu */
	.ibkr-header .navbar-bottom .dropdown-language {
		position: absolute;
		left: 0;
		right: 0;
		top: 45px;
		margin: 0 auto;
		min-width: 140px;
		min-height: 180px;
		display: flex;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu.dropdown-language a.dropdown-item {
		color: var(--dark);
		font-size: var(--fs-8);
		line-height: var(--lh-8);
		font-weight: var(--fw-300);
		transition: color 0.1s ease, background 0.3s ease;
		padding: 5px 10px;
	}
	.ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item .dropdown-menu hr, .ibkr-header .navbar.navbar-bottom .container .navbar-nav .nav-item .dropdown-menu hr.cta-hr {
		border-top: 1px solid var(--dark-10);
	}
	.ibkr-header .navbar-bottom .dropdown-menu .inline-icon svg {
		position: relative;
		bottom: 2px;
		fill: var(--gray-70);
	}
	/* =========================================================
   OPEN STATE RULES
   - Bootstrap opens dropdowns by adding .show to .dropdown-menu
   - Megamenus also open on hover/focus (CSS-driven)
   ========================================================= */
	/* Bootstrap-driven open state (Search/Language + any clicked dropdown) */
	.ibkr-header .navbar-bottom .dropdown-menu.show {
		opacity: 0;
		visibility: hidden;
		pointer-events: auto;
		display: block;
	}
	/* CSS-driven hover/focus state for bottom megamenus only */
	.ibkr-header .navbar-bottom .nav-item.dropdown:hover>.dropdown-menu.bottom-group, .ibkr-header .navbar-bottom .nav-item.dropdown:focus-within>.dropdown-menu.bottom-group, .ibkr-header .navbar-bottom .dropdown-menu.bottom-group:hover {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		min-height: 100px;
		max-height: 800px;
		transition: opacity 0.05s ease, max-height 0.5s ease-out, visibility 0s linear 0s;
	}
	/* Language dropdown menu */
	.ibkr-header .navbar-bottom .dropdown-menu.dropdown-language.show {
		display: inline-table;
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.05s ease, visibility 0s linear 0s;
		width: 160px;
		position: absolute;
		top: 42px;
		left: auto;
		right: 10px;
		border-top: 4px solid var(--primary);
	}
	[dir="rtl"] .ibkr-header .navbar-bottom .dropdown-menu.dropdown-language.show {
		left: 10px;
		right: auto;
	}
	.ibkr-header .navbar-bottom .dropdown-menu.dropdown-language .container {
		padding: 8px;
	}
	/* show menu caret for laguage selections only */
	.ibkr-header .navbar-bottom .dropdown-menu.dropdown-language::after {
		display: none;
		/*block;*/
	}
	/* Base nav-link setup for dropdown items */
	.ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link {
		position: relative;
		display: inline-flex;
		align-items: center;
		color: var(--dark);
		transition: color 0.18s ease;
		padding: 0px 15px 12px;
		margin-bottom: 2px;
	}
	/* stacking safety */
	.ibkr-header .navbar-top .dropdown-menu::after {
		display: none;
	}
	.ibkr-header .navbar-bottom .dropdown-menu::after {
		display: none;
	}
	.ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link::after {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-top: none;
		border-inline-end: 1px solid currentColor;
		border-bottom: 1px solid currentColor;
		border-inline-start: none;
		transform: rotate(45deg);
		margin-left: 8px;
		margin-right: 4px;
		margin-bottom: 4px;
	}
	[dir="rtl"] .ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link::after {
		margin-left: 4px;
		margin-right: 8px;
	}
	/*	overwrite bootstrap default nav colors*/
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item {
		color: var(--dark);
		font-size: 1rem;
		font-weight: 400;
		padding-bottom: 0.5rem;
		border-inline-start: 2px solid transparent;
		border-inline-end: 2px solid transparent;
		padding: 10px 10px;
		transition: color 0.1s ease-in-out, background 0.3s ease-in-out, border-color 0.3 ease-in-out;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item .label-subtitle {
		font-size: 0.8rem;
		margin-top: 1px;
		color: var(--dark-60);
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu .menu-col-header {
		color: var(--dark-60);
		font-size: 1rem;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item:hover {
		color: var(--primary);
		border-inline-start: 2px solid var(--primary);
		border-inline-end: 2px solid transparent;
	}
	[dir="rtl"] .ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item:hover {
		border-inline-end: 2px solid var(--primary);
		border-inline-start: 2px solid transparent;
	}
	/* Underline: bar that animates in/out */
	.ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link::before {
		content: "";
		position: absolute;
		width: 100%;
		right: 0;
		bottom: -4px;
		height: 4px;
		background: var(--primary);
		transform: scaleX(0.1);
		transform-origin: left;
		opacity: 0;
		transition: transform 0.18s ease-in-out, opacity 0.18s ease-in-out;
	}
	/* Don't show caret next to language/search/login in logo row */
	.ibkr-header .navbar-bottom .logo-row-nav .nav-item.dropdown>.nav-link::after {
		display: none;
	}
	/* ACTIVE STATES: color + underline on hover, focus, .show or .active */
	.ibkr-header .navbar-bottom .nav-item.dropdown:hover>.nav-link, .ibkr-header .navbar-bottom .nav-item.dropdown:focus-within>.nav-link, .ibkr-header .navbar-bottom .nav-item.dropdown.show>.nav-link, .ibkr-header .navbar-bottom .nav-item.dropdown.active>.nav-link, .ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link.active, .ibkr-header .navbar-bottom .nav-link.show {
		color: var(--primary);
	}
	.ibkr-header .navbar-bottom .nav-item.dropdown:hover>.nav-link::before, .ibkr-header .navbar-bottom .nav-item.dropdown:focus-within>.nav-link::before, .ibkr-header .navbar-bottom .nav-item.dropdown.show>.nav-link::before, .ibkr-header .navbar-bottom .nav-item.dropdown.active>.nav-link::before, .ibkr-header .navbar-bottom .nav-item.dropdown>.nav-link.active::before {
		transform: scaleX(1);
		opacity: 1;
	}
	.cta-hr {
		margin-top: 30px;
		margin-bottom: 20px;
	}
}
/* SHALLOW LAPTOP ---------------------------------------- */
@media (min-width: 992px) and (max-height: 799.98px) {  
	.mega-cta .headline {
		font-size: 1.5rem;
		line-height: 1.1;
		padding-bottom: 0;
	}
	.mega-cta .headline-sub {
		font-size: 1.25rem;
		line-height: 1.1;
	}
    .mega-cta p {
        line-height: 1.3;
    }
	.mega-cta img.cta-qr {
		max-width: 100px;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item {
		padding: 8px 10px;
	}
	@layer bootstrap {
		.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item .label-subtitle {
			display: none !important;
		}
	}
	.cta-hr {
		margin-top: 20px;
		margin-bottom: 20px;
	}
}
@media (min-width: 992px) and (max-height: 699.98px) {  
	.mega-cta {
		padding: 1.5rem !important;
	}
	.mega-cta .headline {
		font-size: 1.375rem;
	}
	.mega-cta .headline-sub {
		font-size: 1.125rem;
	}
    .mega-cta p {
        line-height: 1.3;
		font-size: .875rem;
    }
	.mega-cta p a {
		line-height: 1;
		font-size: .875rem;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item {
		padding: 6px 8px;
		font-size: .875rem;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu .menu-col-header {
		font-size: .875rem;
	}
}
@media (min-width: 992px) and (max-height: 599.98px) {  
	.mega-cta .headline {
		font-size: 1.25rem;
	}
	.mega-cta .headline-sub {
		font-size: 1rem;
	}
	.ibkr-header .navbar.navbar-bottom .dropdown-menu a.dropdown-item {
		padding: 4px 8px;
	}
	.cta-hr {
		margin-top: 10px;
		margin-bottom: 10px;
	}
}
/* MOBILE MENU ----------------------------------------*/
.menu-mobile .submenu ul li .label-subtitle {
	font-size: var(--fs-8);
}
/* END MOBILE MENU ----------------------------------------*/
@media (min-width: 1200px) {
	.mega-cta {
		padding: 40px;
	}
}
@media (min-width: 1400px) {
	.ibkr-header .navbar-bottom .dropdown-menu.dropdown-why-ibkr, .ibkr-header .navbar-bottom .dropdown-menu.dropdown-education {
		width: 1050px;
		left: 350px;
		right: 0;
	}
	.ibkr-header .navbar-bottom .dropdown-menu.dropdown-language.show {
		left: 1200px;
		right: 0;
	}
	[dir="rtl"] .ibkr-header .navbar-bottom .dropdown-menu.dropdown-why-ibkr, [dir="rtl"] .ibkr-header .navbar-bottom .dropdown-menu.dropdown-education {
		right: 350px;
		left: 0;
	}
	[dir="rtl"] .ibkr-header .navbar-bottom .dropdown-menu.dropdown-language.show {
		left: 0;
		right: 1200px;
	}
}</style>
