<script>
    // Configuration: Which contracts to display
    const CONTRACTS_TO_DISPLAY = ['republican', 'bitcoin', 'feddecision', 'climate'];
    const MAX_ITEMS = 4;
    const API_URL = 'https://www.interactivebrokers.com/response_handlers/fcastex/livedata.php';
    // Configuration: Custom routes for specific contracts
    const CONTRACT_ROUTES = {
        'republican': '/election-hub/grid',
        // Default route for all other contracts is '/markets'
    };
    /**
     * Fetch forecast data from API
     * Returns null if fetch fails
     */
    async function fetchForecastData() {
        try {
            const response = await fetch(API_URL);
            if (!response.ok) {
                return null;
            }
            const data = await response.json();
            return data;
        } catch (error) {
            return null;
        }
    }
    /**
     * Validate that a value is a valid number
     * Accepts numbers and numeric strings, rejects NaN, Infinity, null, undefined, empty strings
     */
    function isValidNumber(value) {
        if (value === null || value === undefined || value === '') {
            return false;
        }
        const numericValue = typeof value === 'number' ? value : parseFloat(value);
        if (isNaN(numericValue) || !isFinite(numericValue)) {
            return false;
        }
        // Ensure it's a valid probability (0 to 1)
        if (numericValue < 0 || numericValue > 1) {
            return false;
        }
        return true;
    }
    /**
     * Sanitize contract key to prevent XSS attacks
     * Only allows alphanumeric characters and underscores
     */
    function sanitizeContractKey(key) {
        if (typeof key !== 'string') {
            return '';
        }
        // Only allow alphanumeric characters and underscores
        return key.replace(/[^a-zA-Z0-9_]/g, '');
    }
    /**
     * Get the appropriate route for a contract
     * Returns sanitized route path, defaults to '/markets'
     */
    function getContractRoute(contractKey) {
        // Check if contract has a custom route
        if (CONTRACT_ROUTES.hasOwnProperty(contractKey)) {
            const route = CONTRACT_ROUTES[contractKey];
            // Validate route is a string and starts with /
            if (typeof route === 'string' && route.startsWith('/')) {
                // Sanitize route to only allow safe characters
                // Allow: letters, numbers, hyphens, underscores, forward slashes
                const sanitizedRoute = route.replace(/[^a-zA-Z0-9\-_/]/g, '');
                return sanitizedRoute;
            }
        }
        // Default route
        return '/markets';
    }
    /**
     * Validate that a single item has all required fields with valid data
     */
    function isValidItem(item) {
        // Check basic field existence
        const hasRequiredFields = item &&
            typeof item.question === 'string' &&  // Add type check
            item.question !== '';
        if (!hasRequiredFields) {
            return false;
        }
        // Validate yesQuote is a valid number
        if (!isValidNumber(item.yesQuote)) {
            return false;
        }
        // Validate noQuote is a valid number
        if (!isValidNumber(item.noQuote)) {
            return false;
        }
        return true;
    }
    /**
     * Extract and validate the contracts we want to display
     * Returns array of valid items with their contract keys, or null if any are invalid
     */
    function getValidContracts(data) {
        if (!data || typeof data !== 'object') {
            return null;
        }
        const contracts = [];
        // Extract desired contracts in order, keeping track of their keys
        for (let contractKey of CONTRACTS_TO_DISPLAY) {
            if (data[contractKey]) {
                contracts.push({
                    key: contractKey,
                    data: data[contractKey]
                });
            }
        }
        // Limit to max items
        const limitedContracts = contracts.slice(0, MAX_ITEMS);
        if (limitedContracts.length === 0) {
            return null;
        }
        // Validate ALL items have required fields with valid numeric data
        const allValid = limitedContracts.every(contract => isValidItem(contract.data));
        if (!allValid) {
            return null;
        }
        return limitedContracts;
    }
    /**
     * Format quote as percentage (e.g., 0.75 -> "75%")
     */
    function formatQuote(quote) {
        const numericValue = typeof quote === 'number' ? quote : parseFloat(quote);
        return `${(numericValue * 100).toFixed(0)}%`;
    }
    /**
     * Populate carousel items with contract data
     */
    function populateCarouselItems(contracts) {
        contracts.forEach((contract, index) => {
            const nameEl = document.getElementById(`name-${index}`);
            const yesQuoteEl = document.getElementById(`yesQuote-${index}`);
            const noQuoteEl = document.getElementById(`noQuote-${index}`);
            const linkEl = document.getElementById(`link-${index}`);
            if (nameEl && yesQuoteEl && noQuoteEl && linkEl) {
                nameEl.textContent = contract.data.question;
                yesQuoteEl.textContent = formatQuote(contract.data.yesQuote);
                noQuoteEl.textContent = formatQuote(contract.data.noQuote);
                // Update link with sanitized contract key and appropriate route
                const sanitizedKey = sanitizeContractKey(contract.key);
                const route = getContractRoute(contract.key);
                const baseUrl = 'https://forecasttrader.interactivebrokers.com/eventtrader/';
                linkEl.href = `${baseUrl}?sbanner=${sanitizedKey}#${route}`;
            }
        });
    }
    /**
     * Show dynamic carousel and hide static content
     */
    function showDynamicContent() {
        const staticEl = document.getElementById('carouselFtStatic');
        const dynamicEl = document.getElementById('carouselFtData');
        if (staticEl) staticEl.style.display = 'none';
        if (dynamicEl) dynamicEl.style.display = 'block';
    }
    /**
     * Keep static content visible (default state)
     */
    function showStaticContent() {
        // Static content is already visible by default, no action needed
    }
    /**
     * Set carousel to height of tallest item to prevent jumping
     * Measures without causing visual flash
     */
    function setCarouselHeight() {
		const smDown = window.matchMedia('(max-width: 575.98px)');
        const smUp = window.matchMedia('(min-width: 576px)');
		const carousel = document.getElementById('carouselFtData');
		if (!carousel) return;
        const carouselContainer = carousel.querySelector('.carousel');
        const carouselInner = carousel.querySelector('.carousel-inner');
        const items = carousel.querySelectorAll('.carousel-item');
        const carouselDisclosure = carousel.querySelector('.ft-livedata-disclosure');
		const carouselDisclosureWidth = carouselDisclosure ? carouselDisclosure.offsetWidth : 0;
        if (!carouselInner || items.length === 0) return;
        // Set max-width. We need to do this first so that we have the wrapping place when it measures the height
        if (smUp.matches) {
            const carouselMaxWidth = carouselDisclosureWidth * 2
            carouselContainer.style.maxWidth = `calc(100% - ${carouselMaxWidth}px)`;
        } else {
            carouselContainer.style.maxWidth = '';
        }
        // Find which item is currently active
        let activeItem = null;
        let activeIndex = -1;
        items.forEach((item, index) => {
            if (item.classList.contains('active')) {
                activeItem = item;
                activeIndex = index;
            }
        });
        carouselInner.style.height = '';
        // Make all items active. The carousel is set to opacity:0 until the height is renders
        let maxHeight = 0;
        items.forEach((item, index) => {
            item.classList.add('active');
            // Measure height
			const height = item.offsetHeight;
            if (height > maxHeight) maxHeight = height;
        });
        // Restore original state: only the original active item should be active
        items.forEach((item, index) => {
            if (index !== activeIndex) {
                item.classList.remove('active');
            }
        });
        // Set min-height and remove overflow hidden
        if (maxHeight > 0) {
            carouselInner.style.height = `${maxHeight}px`;
            carousel.style.opacity = '';
        }
    }
    /**
     * Main initialization function
     */
    async function initializeBanner() {
        // Fetch data from API
        const data = await fetchForecastData();
        // If fetch failed, show static content
        if (!data) {
            showStaticContent();
            return;
        }
        // Validate and extract contracts
        const validContracts = getValidContracts(data);
        // If validation failed, show static content
        if (!validContracts) {
            showStaticContent();
            return;
        }
        // Populate carousel with valid data
        populateCarouselItems(validContracts);
        // Switch to dynamic content (must be visible before measuring)
        showDynamicContent();
        // Set equal height for all carousel items (after content is visible)
        setCarouselHeight();
        // Recalculate height on window resize
        if (!window._forecastCarouselResizeAdded) {
            window.addEventListener('resize', setCarouselHeight);
            window._forecastCarouselResizeAdded = true;
        }
    }
    // Initialize when DOM is ready
    document.addEventListener('DOMContentLoaded', initializeBanner);
</script>
