    <style>
div#ibkr-header, footer#footer, #toTop, .at4-show, .social-sidebar, #page-title, #uk-disclosure { display: none }
.addthis-smartlayers, div#at4-follow, div#at4-share, div#at4-thankyou, div$at4-whatsnext { display: none }
