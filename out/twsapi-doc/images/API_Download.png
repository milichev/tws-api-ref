<style type="text/css">
        .bandaid {
            position: relative;
        }
        .bandaid .bandaid-text,
        .bandaid a {
            color: #fff !important;
            font-size: 14px;
            line-height: 1.3;
        }
        @layer legacy{
            .bandaid .btn.btn-sm {
                width: auto !important;
                font-size: 12px !important;
                line-height: 1 !important;
                padding-right: .625rem !important;
                padding-left: .625rem !important;
            }
            .bandaid .btn-sm.btn-outline.btn-default, 
            .bandaid .btn-sm.btn-outline.btn-default:hover, 
            .bandaid .btn-sm.btn-outline.btn-default:active, 
            .bandaid .btn-sm.btn-outline.btn-default:focus {
                color: white !important;
                border-color: white !important;
                font-weight: 600 !important;
            }
            .bandaid .btn-sm.btn-outline.btn-default:focus {
                outline: solid 2px rgba(255,255,255,.5) !important;
            }
        }
        .bandaid .carousel-item-next, .bandaid .carousel-item-prev, .bandaid .carousel-item.active {
            display: flex;
            height: 100%;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .ft-persistent-banner {
            --info: #1257bf !important;
        }
        .ft-livedata, .ft-staticdata {
            transition: opacity 300ms ease;
        }
        .ft-livedata {
            display:flex;
        }
        .ft-livedata-disclosure {
            display: flex;
            text-align: end;
            position: absolute;
        }
        .ft-livedata-disclosure-link {
            display: block;
        }
        @media(max-width: 1023.98px) {
            .ft-livedata {
                flex-direction: column;
            }
            .ft-livedata-disclosure {
                inset-inline-end: 0px;
                bottom: 0px;
            }
            .ft-livedata-disclosure-link {
                font-size: .625rem !important;
                padding: .375rem 0px;
            }
        }
        @media(min-width: 1024px) {
            .ft-livedata-disclosure {
                inset-inline-end: 0px;
                top: 0px;
                height: 100%;
            }
            .ft-livedata-disclosure-link {
                margin: auto;
                font-size: .6875rem !important;
                padding: .5rem 1rem;
            }
        }
    </style>
