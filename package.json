{
  "name": "@vadymecum/tws-api-ref",
  "version": "0.1.0",
  "description": "Cleaned, section-split, and Markdown-formatted IBKR TWS API documentation. Optimized for LLM context windows and Agentic workflows.",
  "main": "lib/split.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "tsx lib/generate.ts",
    "serve-html": "npx -y http-server ./html",
    "serve-skill": "npx -y docsify-cli serve ./skill",
    "serve-skill-old": "npx -y vitepress dev ./skill",
    "install-skill": "tsx lib/install-skill.ts",
    "mcp": "npx -y @modelcontextprotocol/server-filesystem ./skill"
  },
  "keywords": [
    "tws",
    "api",
    "ibkr",
    "interactive",
    "brokers"
  ],
  "author": {
    "name": "Vadym Milichev",
    "email": "vadim.milichev@gmail.com"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "handlebars": "^4.7.9",
    "tsx": "^4.21.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
